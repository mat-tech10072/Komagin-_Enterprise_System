Options -Indexes

# ── Deny access to dotfiles AND dot-directories (.git, .env, etc.) ──
# Phase 6, Stage 6.5: found live that .git/config, .git/HEAD, and
# .git/logs/HEAD were all served (HTTP 200) — a full source-history
# dump was possible via any git-dumper tool. This app has no public/-
# style document root separating code from the web root, so anything
# not explicitly denied is servable. <FilesMatch> alone only matches
# the leaf filename, not a path segment like ".git/", so a request
# for .git/config (leaf name "config") would slip past it — this
# needs mod_rewrite to match the full request path instead.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} (^|/)\.
    RewriteRule .* - [F]
</IfModule>
<IfModule !mod_rewrite.c>
    <IfModule mod_access_compat.c>
        <FilesMatch "^\.">
            Deny from all
        </FilesMatch>
    </IfModule>
    <IfModule !mod_access_compat.c>
        <FilesMatch "^\.">
            Require all denied
        </FilesMatch>
    </IfModule>
</IfModule>

# ── Browser caching for static assets ──────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 7 days"
    ExpiresByType application/javascript    "access plus 7 days"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/jpeg                "access plus 30 days"
    ExpiresByType image/gif                 "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
    ExpiresByType image/x-icon              "access plus 30 days"
    ExpiresByType font/woff2                "access plus 30 days"
    ExpiresByType font/woff                 "access plus 30 days"
</IfModule>

# ── Cache-Control headers ────────────────────────────────────────
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|ico|woff2|woff)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Phase 6, Stage 6.1 (KOM-054): HSTS — browsers only ever honor this
    # header when it arrives over an already-HTTPS connection (per spec),
    # so sending it unconditionally here is inert and harmless on this
    # local dev environment (plain HTTP, no cert) and becomes meaningful
    # automatically the moment HTTPS is live in production — no code
    # change needed at that point. max-age is 6 months; raise once HTTPS
    # has been confirmed stable in production for a while.
    Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains"

    # Phase 6, Stage 6.1 (KOM-054): Content-Security-Policy, intentionally
    # Report-Only. This codebase makes extensive, pre-existing use of
    # inline <style> blocks, inline style="" attributes, inline <script>
    # blocks, and inline onclick="" handlers throughout — none of that is
    # new to Phase 6, and rewriting it to be strict-CSP-compliant (nonces
    # or moving every inline handler to external files) would be a UI/
    # frontend rewrite, which this phase's charter explicitly prohibits.
    # 'unsafe-inline' is included so the policy doesn't silently break
    # the existing UI; it still provides real protection by restricting
    # which origins scripts/styles/fonts/images/connections may load
    # from at all, closing off a real class of XSS payloads (loading an
    # attacker-controlled script/exfiltrating data to an attacker
    # domain). Report-Only means browsers log violations to the console
    # without blocking anything — the standard, safe way to introduce
    # CSP to an app that wasn't built CSP-first. Switch to the
    # enforcing "Content-Security-Policy" header (drop "-Report-Only")
    # only after confirming zero console violations against real traffic
    # on the actual production domain — see the deployment guide.
    Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
</IfModule>

# ── GZip compression ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── PHP output buffering for faster TTFB ────────────────────────
<IfModule mod_php.c>
    php_value output_buffering 4096
</IfModule>
