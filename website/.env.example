# ============================================================
# KOMAGIN WEBSITE — Environment Configuration
# ============================================================
# This file is a reference only — it is committed to git and must never
# contain real credentials.
#
# These are NOT read from a .env file at runtime (no dotenv loader is
# wired up). Set them as actual server environment variables instead:
#   - DigitalOcean droplet (Nginx + PHP-FPM): env[] directives in the
#     site's PHP-FPM pool config, e.g.
#     /etc/php/8.2/fpm/pool.d/komagin-website.conf
#   - cPanel: SetEnv lines in the root .htaccess
#   - Local XAMPP dev: leave unset — admin/db_config.php falls back to
#     root / no password / komagin_db
# See admin/db_config.php for the full fallback logic and per-host
# instructions.
# ============================================================

# Database Credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=komagin_website
DB_USER=komagin_web
DB_PASS=
