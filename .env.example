# ============================================================
# KOMAGIN HR MANAGEMENT SYSTEM — Environment Configuration
# ============================================================
# Copy this file to .env and set your values.
# NEVER commit .env to version control.
#
# To use: set these as server environment variables (Apache SetEnv,
# PHP-FPM env, or Docker --env). The application reads them via getenv().
# ============================================================

# Application Environment
# Values: development | production
APP_ENV=development

# Application Base URL (no trailing slash)
APP_URL=http://localhost/HR_Komagin

# Database Credentials
DB_HOST=localhost
DB_NAME=komagin_hr
DB_USER=root
DB_PASS=

# Session lifetime in seconds (default 28800 = 8 hours)
SESSION_LIFETIME=28800

# Timezone (PHP timezone string) — this is the business's actual
# operating timezone (Papua New Guinea); only change this if the
# deployment genuinely operates in a different timezone.
APP_TIMEZONE=Pacific/Port_Moresby

# Upload path (absolute server path, trailing slash required)
# Default: auto-resolved relative to project root
UPLOAD_PATH=

# Max file upload size in bytes (default 10MB)
MAX_FILE_SIZE=10485760

# Employee number prefix
EMP_PREFIX=KOM-EMP

# ============================================================
# PRODUCTION CHECKLIST
# ============================================================
# [ ] Set APP_ENV=production
# [ ] Set a strong DB_PASS
# [ ] Enable HTTPS and update APP_URL to https://
# [ ] Change default admin password (Admin@123)
# [ ] Configure log rotation for logs/php_errors.log
# [ ] Verify uploads/ directory permissions (755)
# [ ] Verify uploads/.htaccess blocks PHP execution
# [ ] Remove all test data (fixture data from Phase 7)
